# ─── 发布包专用 .gitignore ───
# MeU GitHub 仓库：只发布宣传文件和文档，不包含源代码

# 本地开发环境
node_modules/
.env
.env.local
.env.*.local

# 日志
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 构建产物
dist/
build/
*.jsbundle

# 编辑器
.vscode/
.idea/
*.swp
*.swo
*~

# 操作系统
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# 私密配置（不公开）
config/
*.key
*.pem
*.cert

# 用户数据（绝对不公开）
memory/
data/
*.db
*.sqlite

# 临时文件
tmp/
temp/
*.tmp
